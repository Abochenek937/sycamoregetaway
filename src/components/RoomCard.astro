---
import type { Room } from "../data/rooms";
interface Props { room: Room; }
const { room } = Astro.props;
---

<a
  href={`/rooms/${room.slug}/`}
  class="group block rounded-3xl border border-forest-100 bg-white hover:shadow-lg transition-shadow overflow-hidden"
>
  <div class="aspect-[4/3] bg-forest-100 relative overflow-hidden">
    {room.photos && room.photos[0] ? (
      <img
        src={room.photos[0]}
        alt={`${room.name} at Sycamore Getaway`}
        loading="lazy"
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center">
        <svg viewBox="0 0 120 120" class="w-24 h-24 opacity-40" aria-hidden="true">
          <path d="M60 12c-8 16-22 22-22 40 0 11 7 19 15 22v34h14V74c8-3 15-11 15-22 0-18-14-24-22-40z" fill="var(--color-forest-500)"/>
        </svg>
      </div>
    )}
    <div class="absolute top-3 left-3 text-xs font-medium uppercase tracking-wider bg-cream-50/95 text-forest-700 px-2.5 py-1 rounded-full backdrop-blur">
      {room.tree}
    </div>
    {room.featured && (
      <div class="absolute top-3 right-3 text-xs font-medium bg-wood-600 text-white px-2.5 py-1 rounded-full">
        Master Suite
      </div>
    )}
  </div>
  <div class="p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-display text-xl text-forest-900 group-hover:text-forest-700 transition-colors">
        {room.name}
      </h3>
      <div class="text-right shrink-0">
        <div class="font-display text-2xl text-forest-900 leading-none">${room.nightly}</div>
        <div class="text-xs text-forest-700/70">per night</div>
        <div class="text-[10px] mt-1 inline-block bg-forest-100 text-forest-700 px-1.5 py-0.5 rounded-full font-medium">No cleaning fee</div>
      </div>
    </div>
    <p class="text-sm text-forest-700/80 mt-1">{room.bed} · {room.bath}</p>
    <p class="text-sm text-forest-800/90 mt-3 line-clamp-2">{room.blurb}</p>
    <div class="mt-4 inline-flex items-center text-sm font-medium text-forest-700 group-hover:text-forest-900">
      View room
      <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M13 6l6 6-6 6"/>
      </svg>
    </div>
  </div>
</a>
