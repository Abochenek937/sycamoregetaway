---
// Per-room mini-calendar grid for the next 3 months.

import { isDateBlocked, type Booking } from '../lib/ical';

interface Props { bookings: Booking[]; }
const { bookings } = Astro.props;

function pad(n: number) { return String(n).padStart(2, '0'); }

// Anchor "today" to America/New_York so day-rollover happens at midnight ET, not midnight UTC.
const nyParts = new Intl.DateTimeFormat('en-CA', {
  timeZone: 'America/New_York',
  year: 'numeric', month: '2-digit', day: '2-digit',
}).formatToParts(new Date());
const nyYear  = Number(nyParts.find(p => p.type === 'year')!.value);
const nyMonth = Number(nyParts.find(p => p.type === 'month')!.value);
const nyDay   = Number(nyParts.find(p => p.type === 'day')!.value);
const todayYmd = `${nyYear}-${pad(nyMonth)}-${pad(nyDay)}`;
const today = new Date(Date.UTC(nyYear, nyMonth - 1, nyDay));

type Month = { name: string; year: number; weeks: ({ ymd: string; day: number; blocked: boolean; past: boolean } | null)[][] };

function buildMonth(year: number, month0: number): Month {
  const firstDay = new Date(Date.UTC(year, month0, 1));
  const daysInMonth = new Date(Date.UTC(year, month0 + 1, 0)).getUTCDate();
  const leadingBlanks = firstDay.getUTCDay(); // 0 = Sunday
  const cells: ({ ymd: string; day: number; blocked: boolean; past: boolean } | null)[] = [];
  for (let i = 0; i < leadingBlanks; i++) cells.push(null);
  for (let d = 1; d <= daysInMonth; d++) {
    const ymd = `${year}-${pad(month0+1)}-${pad(d)}`;
    cells.push({
      ymd,
      day: d,
      blocked: isDateBlocked(ymd, bookings),
      past: ymd < todayYmd,
    });
  }
  while (cells.length % 7 !== 0) cells.push(null);
  const weeks: typeof cells[] = [];
  for (let i = 0; i < cells.length; i += 7) weeks.push(cells.slice(i, i + 7));
  return {
    name: firstDay.toLocaleDateString('en-US', { month: 'long', timeZone: 'UTC' }),
    year,
    weeks,
  };
}

const months: Month[] = [];
for (let i = 0; i < 3; i++) {
  const d = new Date(today);
  d.setUTCDate(1);
  d.setUTCMonth(d.getUTCMonth() + i);
  months.push(buildMonth(d.getUTCFullYear(), d.getUTCMonth()));
}

const dayHeaders = ['S','M','T','W','T','F','S'];
---

<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
  {months.map((m) => (
    <div class="rounded-2xl border border-forest-100 bg-white p-4">
      <div class="font-display text-lg text-forest-900 mb-3">{m.name} <span class="text-sm text-forest-700/60">{m.year}</span></div>
      <div class="grid grid-cols-7 gap-1 text-xs text-center text-forest-700/60 mb-1">
        {dayHeaders.map((h) => <div>{h}</div>)}
      </div>
      <div class="grid grid-cols-7 gap-1">
        {m.weeks.flat().map((cell) => (
          cell === null ? (
            <div></div>
          ) : (
            <div
              class={`aspect-square rounded text-xs flex items-center justify-center font-medium ${
                cell.past ? 'text-forest-400/50' :
                cell.blocked ? 'bg-wood-500 text-white' :
                'bg-forest-100 text-forest-800'
              }`}
              title={`${cell.ymd} · ${cell.blocked ? 'Booked' : 'Available'}`}
            >{cell.day}</div>
          )
        ))}
      </div>
    </div>
  ))}
</div>
<div class="mt-4 flex items-center gap-4 text-xs text-forest-700/80 justify-center">
  <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-forest-100"></span>Available</span>
  <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-wood-500"></span>Booked</span>
</div>
