---
import Base from "../../layouts/Base.astro";

const contactEmail = "alexander.bochenek@outlook.com";
---

<Base
  title="Weddings & Events — Coming Soon"
  description="Sycamore Getaway is planning a future seasonal outdoor wedding and event venue on six wooded acres in southwest Dayton. Vendors invited to get on the radar early."
>
  <section class="max-w-4xl mx-auto px-5 py-20">
    <p class="uppercase tracking-wider text-forest-600 text-xs font-medium">Weddings & Events</p>
    <h1 class="font-display text-4xl md:text-6xl mt-2 text-forest-900 leading-[1.05]">
      An outdoor wedding venue<br/>in the Dayton woods.
    </h1>
    <p class="mt-6 text-lg text-forest-800/90 max-w-2xl">
      Sycamore Getaway is planning a seasonal outdoor wedding and event venue on its six wooded
      acres in southwest Dayton. Quiet, private, framed by sycamores and black walnuts, with
      room for ceremonies, receptions, and the small intentional gatherings that make the day.
    </p>

    <div class="mt-6">
      <span class="inline-flex items-center gap-1.5 bg-wood-50 border border-wood-200 text-wood-800 text-xs font-medium px-3 py-1 rounded-full uppercase tracking-wider">
        <span class="w-2 h-2 rounded-full bg-wood-500"></span>
        In planning · Coming in the future
      </span>
    </div>

    {/* ──────────── RENDERINGS PLACEHOLDER ──────────── */}
    <div class="mt-12 grid sm:grid-cols-2 gap-5">
      {[1, 2].map(() => (
        <div class="aspect-[4/3] rounded-3xl border-2 border-dashed border-forest-200 bg-cream-100 flex items-center justify-center text-center px-6">
          <div>
            <svg viewBox="0 0 24 24" class="w-10 h-10 mx-auto text-forest-400" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <circle cx="9" cy="11" r="2"/>
              <path d="M21 17l-5-5-8 8"/>
            </svg>
            <p class="mt-3 font-display text-lg text-forest-800">Rendering Coming Soon</p>
          </div>
        </div>
      ))}
    </div>

    {/* ──────────── VENDORS ──────────── */}
    <div class="mt-16 rounded-3xl border border-forest-100 bg-white p-8">
      <p class="uppercase tracking-wider text-forest-600 text-xs font-medium">For vendors</p>
      <h2 class="font-display text-2xl md:text-3xl mt-2 text-forest-900">Photographers, caterers, florists, planners — get on the radar early.</h2>
      <p class="mt-4 text-forest-800/90 leading-relaxed">
        We're building a list of trusted vendors to recommend to couples as bookings open up.
        If you're a wedding professional in the Dayton area and want to be considered, reach out
        now. No commitments — we just want to know who's out there.
      </p>
      <a
        href={`mailto:${contactEmail}?subject=Sycamore%20Getaway%20%E2%80%94%20Vendor%20Inquiry`}
        class="mt-6 inline-flex items-center rounded-full bg-forest-700 hover:bg-forest-800 text-white px-6 py-3 font-medium transition-colors"
      >
        <svg viewBox="0 0 24 24" class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="5" width="18" height="14" rx="2"/>
          <path d="M3 7l9 6 9-6"/>
        </svg>
        Email {contactEmail}
      </a>
    </div>

    <p class="mt-12 text-sm text-forest-700/70">
      Couples — bookings aren't open yet. Watch this page or reach out at the email above to be
      notified when we begin.
    </p>
  </section>
</Base>
