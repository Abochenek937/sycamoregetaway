---
// Internal tool — browse all photos organized by category.
// DELETE this file when no longer needed.

import Base from "../layouts/Base.astro";
import fs from "node:fs";
import path from "node:path";

const photosDir = path.join(process.cwd(), "public", "photos");
const categories = fs
  .readdirSync(photosDir, { withFileTypes: true })
  .filter((d) => d.isDirectory())
  .map((d) => d.name)
  .sort();

const all = categories.map((cat) => {
  const dir = path.join(photosDir, cat);
  const files = fs.readdirSync(dir).filter((f) => /\.(jpe?g|png)$/i.test(f)).sort();
  return { cat, files: files.map((f) => `/photos/${cat}/${f}`) };
});
---

<Base title="Photo Picker (private)" description="Internal tool.">
  <section class="max-w-6xl mx-auto px-5 py-10">
    <p class="uppercase tracking-wider text-wood-700 text-xs font-medium">Private tool — delete when done</p>
    <h1 class="font-display text-3xl text-forest-900 mt-2">Photos by category</h1>
    <p class="mt-3 text-forest-800/85 max-w-2xl">
      Photos reorganized into category folders. Each photo has its path below it. Tell Claw the
      filename to use for any spot on the site.
    </p>

    <nav class="mt-6 rounded-2xl border border-forest-100 bg-cream-50 p-4">
      <p class="text-xs uppercase tracking-wider text-forest-600 font-medium mb-2">Jump to:</p>
      <ul class="flex flex-wrap gap-x-4 gap-y-1 text-sm">
        {all.map(({ cat, files }) => (
          <li><a href={`#${cat}`} class="text-forest-700 hover:text-forest-900 underline">{cat} ({files.length})</a></li>
        ))}
      </ul>
    </nav>

    {all.map(({ cat, files }) => (
      <section id={cat} class="mt-10">
        <h2 class="font-display text-2xl text-forest-900 capitalize">{cat.replace(/-/g, ' ')}</h2>
        <p class="text-sm text-forest-700/70">{files.length} photos · path prefix: <code>/photos/{cat}/</code></p>
        <div class="mt-4 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {files.map((src) => {
            const fname = src.split("/").pop();
            return (
              <div class="rounded-2xl overflow-hidden border border-forest-100 bg-white">
                <a href={src} target="_blank" rel="noopener" class="block">
                  <img src={src} alt={fname} loading="lazy" class="w-full aspect-square object-cover" />
                </a>
                <p class="px-3 py-2 text-xs font-mono text-forest-800 bg-cream-50 border-t border-forest-100">
                  {cat} / {fname}
                </p>
              </div>
            );
          })}
        </div>
      </section>
    ))}
  </section>
</Base>
