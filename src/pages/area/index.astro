---
import Base from "../../layouts/Base.astro";

const sections = [
  {
    title: "Where we are",
    items: [
      "Southwest Dayton, next to Jefferson Township High School",
      "~15 minutes to downtown Dayton",
      "~25 minutes to Wright-Patterson AFB",
      "~30 minutes to Dayton International Airport",
    ],
  },
  {
    title: "Food & coffee",
    items: [
      "The Dayton Beer Company — local craft brewery",
      "Press Coffee Bar — downtown coffee + pastries",
      "Salar Restaurant — Peruvian, Oregon District",
      "Oregon District — restaurants, bars, late-night food",
    ],
  },
  {
    title: "Things to do",
    items: [
      "National Museum of the US Air Force — free, world-class",
      "Oregon Historic District — bars, shops, nightlife",
      "Dayton Art Institute — riverfront museum",
      "RiverScape MetroPark — events, fountains, ice rink in winter",
    ],
  },
  {
    title: "For long stays",
    items: [
      "Kroger — 12 minutes east for groceries",
      "Kettering Health, Miami Valley, Premier Health — major hospitals nearby",
      "Sinclair Community College, Wright State, UD — all within reach",
      "Fast Wi-Fi at the house for remote work",
    ],
  },
];

// Featured outdoor/nature spots — Possum Creek is the standout for long-stay guests
// who want trails, fishing, and a real piece of nature within minutes of the house.
const featuredOutdoor = {
  name: "Possum Creek MetroPark",
  driveTime: "~8 minutes",
  blurb:
    "If you're staying for a month or more, this one becomes a habit. Stocked fishing ponds, miles of wooded hiking trails, and an old working farm to walk around. It's the closest real piece of nature to the house, and most weekday afternoons you'll have a trail to yourself.",
  highlights: [
    { label: "Fishing", emoji: "🎣" },
    { label: "Hiking trails", emoji: "🥾" },
    { label: "Outdoor recreation", emoji: "🌲" },
  ],
};

const otherParks = [
  { name: "Germantown MetroPark", driveTime: "~10 min", detail: "Miles of trails through hills and creeks." },
  { name: "Twin Creek MetroPark", driveTime: "~12 min", detail: "Prairie and woodland, quiet and remote." },
  { name: "Carriage Hill MetroPark", driveTime: "~25 min", detail: "Historic working farm, draft horses, family-friendly." },
];

// "Close to where you're working" — drive times to hospitals, bases, schools, and major employers.
const destinations = [
  { name: "Kettering Health Main Campus",     type: "Hospital",         drive: "~15 min" },
  { name: "Miami Valley Hospital",            type: "Hospital",         drive: "~18 min" },
  { name: "Dayton Children's Hospital",       type: "Hospital",         drive: "~20 min" },
  { name: "Premier Health / Good Samaritan",  type: "Hospital",         drive: "~20 min" },
  { name: "Dayton VA Medical Center",         type: "Hospital",         drive: "~20 min" },
  { name: "Wright-Patterson AFB",             type: "Military",         drive: "~25 min" },
  { name: "Wright State University",          type: "University",       drive: "~20 min" },
  { name: "University of Dayton",             type: "University",       drive: "~18 min" },
  { name: "Sinclair Community College",       type: "College",          drive: "~18 min" },
  { name: "Amazon Fulfillment (Moraine)",     type: "Warehouse/Crews",  drive: "~10 min" },
];
---

<Base title="The Area" description="Southwest Dayton, Ohio — next to Jefferson Township High School. Parks, restaurants, museums, hospitals, and the practical stuff you need to know.">
  <section class="max-w-5xl mx-auto px-5 py-16">
    <p class="uppercase tracking-wider text-forest-600 text-xs font-medium">The Area</p>
    <h1 class="font-display text-4xl md:text-5xl mt-2 text-forest-900">Southwest Dayton. Quiet, but close.</h1>
    <p class="mt-6 text-lg text-forest-800/90 max-w-2xl">
      You're next to Jefferson Township High School in southwest Dayton, surrounded by metro
      parks but a short drive from downtown, the Air Force museum, and the major hospitals.
      Exact address is shared with guests after booking.
    </p>

    {/* ──────────── OUTDOOR FEATURE ──────────── */}
    <div class="mt-14">
      <p class="uppercase tracking-wider text-forest-600 text-xs font-medium">Featured outdoor spot</p>
      <h2 class="font-display text-3xl md:text-4xl mt-2 text-forest-900">{featuredOutdoor.name}</h2>
      <div class="mt-6 grid md:grid-cols-3 gap-6 items-start">
        <div class="md:col-span-2 rounded-3xl border border-forest-100 bg-white p-6">
          <p class="inline-flex items-center gap-1.5 text-xs font-medium bg-forest-100 text-forest-700 px-2.5 py-1 rounded-full">
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            {featuredOutdoor.driveTime}
          </p>
          <p class="mt-4 text-forest-800/90 leading-relaxed">{featuredOutdoor.blurb}</p>
          <div class="mt-5 grid grid-cols-3 gap-3">
            {featuredOutdoor.highlights.map((h) => (
              <div class="rounded-2xl bg-cream-100 border border-forest-100 p-4 text-center">
                <div class="text-2xl">{h.emoji}</div>
                <div class="mt-1 text-sm font-medium text-forest-900">{h.label}</div>
              </div>
            ))}
          </div>
        </div>
        <div class="rounded-3xl border border-forest-100 bg-cream-100 p-6">
          <h3 class="font-display text-lg text-forest-900">Other parks nearby</h3>
          <ul class="mt-3 space-y-3">
            {otherParks.map((p) => (
              <li>
                <div class="font-medium text-forest-900 text-sm">{p.name}</div>
                <div class="text-xs text-forest-700/80">{p.driveTime} · {p.detail}</div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    {/* ──────────── EMPLOYER / HOSPITAL DISTANCE TABLE ──────────── */}
    <div class="mt-20">
      <p class="uppercase tracking-wider text-forest-600 text-xs font-medium">Drive times</p>
      <h2 class="font-display text-3xl md:text-4xl mt-2 text-forest-900">Close to where you're working.</h2>
      <p class="mt-3 text-forest-800/85 max-w-2xl">
        Most of our long-stay guests are commuting to one of these places. Here's the math.
      </p>
      <div class="mt-8 overflow-x-auto rounded-3xl border border-forest-100 bg-white">
        <table class="w-full text-sm">
          <thead class="bg-forest-50 text-forest-900">
            <tr>
              <th class="text-left font-medium px-5 py-4">Destination</th>
              <th class="text-left font-medium px-5 py-4">Type</th>
              <th class="text-left font-medium px-5 py-4">Drive time</th>
            </tr>
          </thead>
          <tbody>
            {destinations.map((d, i) => (
              <tr class={i % 2 ? "bg-cream-50" : ""}>
                <td class="px-5 py-3 font-medium text-forest-900">{d.name}</td>
                <td class="px-5 py-3 text-forest-800">{d.type}</td>
                <td class="px-5 py-3 text-forest-800 font-medium">{d.drive}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    {/* ──────────── EVERYTHING ELSE ──────────── */}
    <div class="mt-20 grid md:grid-cols-2 gap-8">
      {sections.map((s) => (
        <div class="rounded-3xl border border-forest-100 bg-white p-6">
          <h3 class="font-display text-2xl text-forest-900">{s.title}</h3>
          <ul class="mt-4 space-y-2 text-forest-800/85">
            {s.items.map((i) => (
              <li class="flex gap-2">
                <span class="text-forest-500 mt-1">•</span>
                <span>{i}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</Base>
