---
import Base from "../../layouts/Base.astro";

const faqs = [
  {
    q: "What's the minimum stay?",
    a: "22 nights. We're a long-stay property built for travel nurses, construction crews, students, military and contractors at Wright-Patt, and people relocating to Dayton. Shorter stays don't fit the vibe.",
  },
  {
    q: "How much does it cost?",
    a: "Standard rooms list at $35/night. The Master Suite (private bath, walk-in closet, work desk) is $44/night. Over a full month (30 nights) with Airbnb's guest service fee, that's about $1,197 all-in for a standard room or $1,505 for the Master — well under a typical Dayton 1-bedroom apartment ($1,742 all-in) once you factor in utilities, internet, furniture, and the lease lock-in. No cleaning fee, ever.",
  },
  {
    q: "What if my contract ends early or my plans change?",
    a: "You can cancel through the end of your current month — no break fees, no lease penalty. A 12-month apartment lease can leave you on the hook for thousands if your travel contract gets cut. We built this for people whose lives are in motion.",
  },
  {
    q: "Will my rate go up if I stay longer?",
    a: "No. The nightly rate you book at is the rate you pay for your entire stay — whether that's 22 nights or 22 months. Apartments hit you with a renewal hike at the end of every lease. We don't.",
  },
  {
    q: "Is there a cleaning fee?",
    a: "No. Zero cleaning fee. We hire a professional cleaner to do a deep clean of the house every two months, and regular maintenance cleaning keeps common spaces tidy in between. Most Airbnbs add $100–200 at checkout — we don't.",
  },
  {
    q: "Am I sharing the house?",
    a: "Yes — each room is bookable on its own. You'll share the kitchen, living areas, deck, and (depending on which room) one of the two common bathrooms with whoever else is staying. The Sycamore Master has its own private bath.",
  },
  {
    q: "How do I check in and check out?",
    a: "Self check-in with a smart lock — the code arrives through the Airbnb app the day of your stay. Check-in is any time after 3:00 PM. Check-out is by 12:00 PM (noon).",
  },
  {
    q: "Where exactly is the property?",
    a: "Southwest Dayton, Ohio, next to Jefferson Township High School. About 15 minutes from downtown Dayton and 25 minutes from Wright-Patterson AFB. The exact address is shared with guests after booking — Airbnb policy.",
  },
  {
    q: "Is the host on the property?",
    a: "Yes — Alex (the host) lives in a separate detached mother-in-law suite on the property. He's easy to reach if you need something, but you'll rarely see him. Self check-in means you can come and go on your own schedule.",
  },
  {
    q: "Do you have specific bedding or linen allergies?",
    a: "Please message the host through Airbnb before your stay if you have allergies to specific detergents, fabrics, or linens. We can usually accommodate with advance notice.",
  },
  {
    q: "Are pets allowed?",
    a: "No pets, sorry. The property has a lot of wildlife (deer, turkeys, owls, mallard ducks, turtles, salamanders, even a bald eagle) and we keep it that way by being pet-free.",
  },
  {
    q: "Is the pool open? Is there a fire pit?",
    a: "The pool is open seasonally, weather permitting — and with only five rooms on the property, it never gets crowded the way a hotel pool does. There's a fire pit by the pool, plus another in the sandy clearing on the corner of the property — the best spot for sunset.",
  },
  {
    q: "Is there Wi-Fi?",
    a: "Yes — fast Wi-Fi throughout the house. Good enough for video calls, remote work, telehealth, online classes.",
  },
  {
    q: "Can I book directly instead of through Airbnb?",
    a: "Please book on Airbnb — it gives us both calendar accuracy, AirCover protection, and easy communication. Every room is bookable in real-time on its own listing.",
  },
  {
    q: "Smoking? Parties?",
    a: "No smoking inside. No parties or events — this is a quiet long-stay property.",
  },
];
---

<Base title="FAQ" description="House rules, check-in, minimum stay, and common questions about Sycamore Getaway.">
  <section class="max-w-3xl mx-auto px-5 py-16">
    <p class="uppercase tracking-wider text-forest-600 text-xs font-medium">FAQ</p>
    <h1 class="font-display text-4xl md:text-5xl mt-2 text-forest-900">Frequently asked.</h1>

    <div class="mt-10 space-y-4">
      {faqs.map((f) => (
        <details class="group rounded-2xl border border-forest-100 bg-white p-5 open:shadow-sm">
          <summary class="cursor-pointer list-none flex items-start justify-between gap-4">
            <span class="font-display text-lg text-forest-900">{f.q}</span>
            <svg class="w-5 h-5 mt-1 text-forest-500 transition-transform group-open:rotate-45 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
          </summary>
          <p class="mt-3 text-forest-800/90 leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>
  </section>
</Base>
